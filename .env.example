# OpenFlix - 2026
# Documentation: https://github.com/sparkly-games/openflix/wiki/

# --- Supabase Configuration ---
# Find these in: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# --- Auth Configuration ---
# List the providers you've enabled in the Supabase Dashboard (comma-separated)
# Example: "google,github,discord,apple"
VITE_ENABLED_AUTH_PROVIDERS=google,github

# --- Ads Configuration ---
VITE_ADS_ENABLED=false
VITE_AD_PROVIDER=adsense # options: adsense, adsterra

# Provider-specific IDs
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSTERRA_KEY=enter_key_here

# TMDB Setup
TMDB_READ_ACCESS_TOKEN=your_token_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE=https://image.themoviedb.org/t/p